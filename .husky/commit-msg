#!/bin/sh

# Validation format commit: [APP-DOMAIN-NNN] ou [APP-DOMAIN-NNNx] type: message
# Exemples:
#   [LM-ORD-009] feat: refonte workflow order form
#   [BO-BRAND-003b] feat: ui complement of BO-BRAND-003 (sub-sprint)
#   [NO-TASK] chore: update dependencies

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Regex: [APP-DOMAIN-NNN] ou [APP-DOMAIN-SUBDOMAIN-NNN] ou [NO-TASK]
# Supporte les domaines composes (ex: [BO-UI-RESP-001], [INFRA-DOC-002])
# Suffixe lettre minuscule optionnel (1 lettre max, ex: 003b, 004c) pour
# split d'un sprint en blocs coherents (DB-only / UI-only) sur le meme domaine.
# Voir INFRA-RULES-003 (2026-05-01) pour le contexte.
pattern="^\[(([A-Z]{2,5}(-[A-Z0-9]{2,10}){1,3}-[0-9]{3}[a-z]?)|NO-TASK)\] (feat|fix|chore|docs|refactor|test|style|perf):"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Commit message invalide"
  echo ""
  echo "Format requis: [APP-DOMAIN-NNN] type: description"
  echo ""
  echo "Exemples valides:"
  echo "  [LM-ORD-009] feat: refonte workflow order form"
  echo "  [BO-DASH-001] fix: cache invalidation"
  echo "  [BO-UI-RESP-001] feat: responsive infrastructure"
  echo "  [BO-BRAND-003b] feat: sub-sprint avec suffixe lettre (1 lettre min. max)"
  echo "  [NO-TASK] chore: update dependencies"
  echo ""
  exit 1
fi
