#!/bin/sh
# PRE-PUSH GUARD — INFRA-CI-GUARD-001 (2026-05-08)
#
# Règle : aucun push ne quitte cette machine sans avoir passé type-check + lint
# sur les apps touchées. Évite ~7 min de CI par fail détectable localement.
#
# Logique partagée avec .claude/settings.json PreToolUse(git push) :
# voir .claude/hooks/validate-affected-apps.sh

REPO_ROOT=$(git rev-parse --show-toplevel)
exec "$REPO_ROOT/.claude/hooks/validate-affected-apps.sh"
