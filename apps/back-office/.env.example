# === Resend Email API (Required for email notifications) ===
# Obtenez votre clé API depuis https://resend.com/api-keys
# Le domaine FROM doit être vérifié sur Resend (DNS SPF/DKIM)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=contact@app.veronecollections.fr
RESEND_REPLY_TO=romeo@veronecollections.fr

# === Qonto API (Required for invoices/quotes/credit-notes) ===
# Docs: https://api-doc.qonto.com/docs/business-api/a475e3e32de03-getting-started
# Dashboard: https://app.qonto.com/settings/integrations
# IMPORTANT: Ces variables DOIVENT être configurées dans Vercel pour la production
QONTO_AUTH_MODE=api_key
QONTO_ORGANIZATION_ID=your-organization-slug
QONTO_API_KEY=your_qonto_api_key_here

# === Comptabilité Welyb — transfert des pièces au comptable ===
# Destinataires Welyb (jamais mettre les vraies valeurs ici)
# ventes → ventes+verone@welyb.fr
# achats → compta+verone@welyb.com
WELYB_VENTES_EMAIL=ventes+verone@welyb.fr
WELYB_ACHATS_EMAIL=compta+verone@welyb.com
# Expéditeur des emails vers le comptable (domaine vérifié sur Resend)
ACCOUNTANT_FROM_EMAIL=noreply-compta@veronecollections.fr
# Garde-fou : mettre à 'true' UNIQUEMENT pour activer les envois réels
# (en combinaison avec confirmSend=true dans le body)
# Laisser vide ou absent = dry-run systématique (aucun email ne part)
ACCOUNTANT_SEND_ENABLED=false

# === Google Gemini (Required for marketing AI image generation) ===
# Studio Marketing IA — generation d'images via Gemini API depuis la
# bibliotheque media (page /marketing/prompts).
# Cle API: https://aistudio.google.com/app/apikey
# Project Cloud Google associe: verone-marketing
# IMPORTANT: ces variables DOIVENT etre configurees dans Vercel pour la production
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT_VERONE_MARKETING=556293936564
GOOGLE_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GOOGLE_GEMINI_FALLBACK_MODEL=gemini-3-pro-image-preview
