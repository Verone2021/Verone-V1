    "@verone/types": "workspace:*",
    "html2canvas": "^1.4.1",
    "isomorphic-dompurify": "^2.36.0",
    "jspdf": "^4.2.1",
    "maplibre-gl": "^4.7.1",
    "next": "^15.5.19",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-map-gl": "^7.1.9",
