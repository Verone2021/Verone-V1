{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "staging": false,
      "main": true
    }
  },
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ]; then echo 'Skip preview — deploy only on main'; exit 1; fi && npx turbo-ignore --fallback=HEAD^1",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@verone/site-internet",
  "outputDirectory": ".next",
  "installCommand": "cd ../.. && pnpm install",
  "crons": [
    {
      "path": "/api/cron/abandoned-cart-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/review-request-check",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/win-back-check",
      "schedule": "0 10 * * 1"
    }
  ]
}
