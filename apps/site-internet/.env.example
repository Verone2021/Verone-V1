# Site Internet Verone - Variables d'environnement
# Copier ce fichier vers .env.local et remplir les valeurs

# ==============================================================================
# SUPABASE
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==============================================================================
# STRIPE (Checkout + Webhooks)
# ==============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==============================================================================
# RESEND (Emails transactionnels)
# ==============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=contact@veronecollections.fr
RESEND_REPLY_TO=veronebyromeo@gmail.com
# Destinataire des notifications du formulaire de contact (équipe Vérone).
# Défaut : contact@veronecollections.fr
CONTACT_NOTIFICATION_EMAIL=contact@veronecollections.fr

# ==============================================================================
# WHATSAPP (notification du formulaire de contact — EN VEILLE)
# ==============================================================================
# Optionnel. Tant qu'une de ces 3 variables manque, la notification WhatsApp est
# inactive (l'email reste la notif principale). Mêmes valeurs Meta que LinkMe.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TO_NUMBER=

# ==============================================================================
# ANALYTICS
# ==============================================================================
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (Facebook Ads)
# Obtenir dans Meta Business Manager > Ensemble de données
NEXT_PUBLIC_META_PIXEL_ID=1973785847346434

# Meta Conversions API (CAPI) — server-side event mirroring (BO-MKT-METRICS-001 Sprint 4)
# Si non défini, le code fallback sur META_ACCESS_TOKEN (System User VeroneCatalog
# déjà configuré côté back-office Vercel) qui a "Contrôle total" sur l'app/dataset
# 1973785847346434 et suffit pour CAPI events submission.
# Optionnel : générer un token dédié via Events Manager > Settings > Conversions API
# si tu veux un token séparé du token catalogue.
META_CAPI_ACCESS_TOKEN=

# ==============================================================================
# APPLICATION
# ==============================================================================
NEXT_PUBLIC_APP_URL=https://veronecollections.fr
