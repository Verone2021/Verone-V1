# Site Internet Verone - Variables d'environnement
# Copier ce fichier vers .env.local et remplir les valeurs

# ==============================================================================
# SUPABASE
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==============================================================================
# STRIPE (Checkout + Webhooks)
# ==============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==============================================================================
# RESEND (Emails transactionnels)
# ==============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=contact@veronecollections.fr
RESEND_REPLY_TO=veronebyromeo@gmail.com

# ==============================================================================
# ANALYTICS
# ==============================================================================
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (Facebook Ads)
# Obtenir dans Meta Business Manager > Ensemble de données
NEXT_PUBLIC_META_PIXEL_ID=1973785847346434

# Meta Conversions API (CAPI) — server-side event mirroring (BO-MKT-METRICS-001 Sprint 4)
# Génère via Meta Ads Manager > Events Manager > [pixel] > Settings > Conversions API > Generate Access Token
# Permet de récupérer +24% de conversions attribuées vs Pixel browser seul (post-iOS14.5)
META_CAPI_ACCESS_TOKEN=

# ==============================================================================
# APPLICATION
# ==============================================================================
NEXT_PUBLIC_APP_URL=https://veronecollections.fr
