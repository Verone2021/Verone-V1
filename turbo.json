{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local",
    ".env",
    "tsconfig.json",
    "turbo.json"
  ],
  "globalPassThroughEnv": ["TURBO_TOKEN", "TURBO_TEAM", "VERCEL_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "cache": true,
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "DATABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "QONTO_AUTH_MODE",
        "QONTO_ORGANIZATION_ID",
        "QONTO_API_KEY",
        "QONTO_API_BASE_URL",
        "LINKME_PUBLIC_URL",
        "GMAIL_SERVICE_ACCOUNT_EMAIL",
        "GMAIL_SERVICE_ACCOUNT_PRIVATE_KEY",
        "GMAIL_PUBSUB_TOPIC",
        "GMAIL_PUBSUB_VERIFICATION_TOKEN",
        "GMAIL_WATCH_ADDRESSES",
        "GMAIL_ACCEPTED_ALIASES",
        "CRON_SECRET",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "RESEND_REPLY_TO"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [],
      "outputs": [],
      "cache": true,
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        ".eslintrc*",
        "eslint.config.*"
      ]
    },
    "lint:fix": {
      "dependsOn": [],
      "outputs": [],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        ".eslintrc*",
        "eslint.config.*"
      ]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": true,
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json", "tsconfig.*.json"]
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": [
        ".playwright-mcp/reports/**",
        "playwright-report/**",
        "test-results/**"
      ],
      "cache": false,
      "env": ["NEXT_PUBLIC_SUPABASE_URL", "SUPABASE_SERVICE_ROLE_KEY"]
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"],
      "cache": true
    }
  },
  "remoteCache": {
    "enabled": true
  },
  "ui": "tui"
}
