{
  "manifest_version": 3,
  "name": "Verone Sourcing Import",
  "version": "1.0.0",
  "description": "Importer des produits depuis Alibaba et autres fournisseurs dans Verone Back-Office",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.alibaba.com/*",
    "https://*.1688.com/*",
    "https://*.aliexpress.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.alibaba.com/product-detail/*",
        "https://*.alibaba.com/company_profile*",
        "https://*.1688.com/offer/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
