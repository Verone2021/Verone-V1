{
  "name": "@verone/consultations",
  "version": "1.0.0",
  "description": "Module consultations pour le système Vérone CRM/ERP",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit"
  },
  "author": "Romeo Dos Santos",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@react-pdf/renderer": "^4.3.1",
    "file-saver": "^2.0.5",
    "@verone/finance": "workspace:*",
    "@verone/orders": "workspace:*",
    "@verone/products": "workspace:*",
    "@verone/ui": "workspace:*",
    "@verone/utils": "workspace:*",
    "@verone/types": "workspace:*"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "import": "./src/hooks/index.ts",
      "require": "./src/hooks/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*/index.ts",
      "import": "./src/components/*/index.ts",
      "require": "./src/components/*/index.ts"
    }
  }
}
