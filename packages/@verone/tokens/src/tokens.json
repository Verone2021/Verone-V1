{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Vérone Design Tokens — tokens neutres cross-marques (W3C format). Couleurs/typo/ombres/radius sont dans @verone/themes (variant par marque).",

  "spacing": {
    "$type": "dimension",
    "$description": "Scale d'espacement en rem (base 16px). Aligné sur la scale Tailwind CSS.",
    "0": { "$value": "0rem", "$description": "0px" },
    "0.5": { "$value": "0.125rem", "$description": "2px" },
    "1": { "$value": "0.25rem", "$description": "4px" },
    "1.5": { "$value": "0.375rem", "$description": "6px" },
    "2": { "$value": "0.5rem", "$description": "8px" },
    "3": { "$value": "0.75rem", "$description": "12px" },
    "4": { "$value": "1rem", "$description": "16px" },
    "6": { "$value": "1.5rem", "$description": "24px" },
    "8": { "$value": "2rem", "$description": "32px" },
    "12": { "$value": "3rem", "$description": "48px" },
    "16": { "$value": "4rem", "$description": "64px" },
    "24": { "$value": "6rem", "$description": "96px" },
    "32": { "$value": "8rem", "$description": "128px" }
  },

  "breakpoints": {
    "$type": "dimension",
    "$description": "Breakpoints responsives Vérone. Alignés sur responsive.md et use-breakpoint.ts.",
    "sm": {
      "$value": "640px",
      "$description": "Grand mobile paysage, petites tablettes"
    },
    "md": {
      "$value": "768px",
      "$description": "Tablette, iPad portrait, Galaxy Fold ouvert"
    },
    "lg": { "$value": "1024px", "$description": "Laptop S, tablette paysage" },
    "xl": { "$value": "1280px", "$description": "Laptop M (MacBook 13/14)" },
    "2xl": {
      "$value": "1536px",
      "$description": "Desktop (MacBook 16, écran externe 1080p+)"
    }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "$description": "Durées d'animation standard. Utiliser 'fast' pour micro-interactions, 'normal' pour transitions UI.",
      "instant": {
        "$value": "0ms",
        "$description": "Sans transition (désactivation immédiate)"
      },
      "fast": {
        "$value": "150ms",
        "$description": "Micro-interactions (hover, focus ring)"
      },
      "normal": {
        "$value": "250ms",
        "$description": "Transitions UI standard (ouverture modal, dropdown)"
      },
      "slow": {
        "$value": "400ms",
        "$description": "Animations larges (sidebar, page transition)"
      }
    },
    "easing": {
      "$type": "cubicBezier",
      "$description": "Courbes d'accélération. Préférer easeOut pour les entrées, easeIn pour les sorties.",
      "linear": { "$value": [0, 0, 1, 1], "$description": "Vitesse constante" },
      "easeIn": {
        "$value": [0.4, 0, 1, 1],
        "$description": "Accélération — sortie d'écran"
      },
      "easeOut": {
        "$value": [0, 0, 0.2, 1],
        "$description": "Décélération — entrée à l'écran"
      },
      "easeInOut": {
        "$value": [0.4, 0, 0.2, 1],
        "$description": "Accélération puis décélération"
      },
      "bounce": {
        "$value": [0.34, 1.56, 0.64, 1],
        "$description": "Rebond léger — feedback positif"
      }
    }
  },

  "zIndex": {
    "$type": "number",
    "$description": "Z-index scale pour la hiérarchie des couches. Ne pas utiliser de valeurs hors de cette scale.",
    "dropdown": {
      "$value": 10,
      "$description": "Menus déroulants, tooltips ancrés"
    },
    "sticky": {
      "$value": 20,
      "$description": "Headers collants, barres de filtre fixes"
    },
    "modal": { "$value": 50, "$description": "Modals, dialogs, drawers" },
    "toast": {
      "$value": 60,
      "$description": "Notifications toast (toujours au-dessus des modals)"
    }
  }
}
